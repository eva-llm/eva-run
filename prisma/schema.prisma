// Prisma schema for eva-run
// Adjust datasource and generator as needed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AssertResult {
  id         String   @id
  test_id    String
  run_id     String
  name       String
  passed     Boolean
  score      Float
  reason     String
  started_at DateTime
  finished_at DateTime
  diff_ms    Int
}

model TestResult {
  id               String   @id
  run_id           String
  prompt           String
  output           String
  passed           Boolean
  started_at       DateTime
  finished_at      DateTime
  diff_ms          Int
  assert_started_at DateTime
  assert_diff_ms    Int
  output_diff_ms    Int
}
